<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Login to the Clubhouse</title>
		<link rel="stylesheet" href="styles.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap"
			rel="stylesheet" />
	</head>
	<body>
		<div class="scene">
			<div class="noise"></div>

			<div class="card">
				<div class="card__header">
					<div class="logo">
						<span class="logo__icon">✦</span>
					</div>
					<h1 class="card__title">Login to the Clubhouse</h1>
				</div>

     <div style="margin-bottom: 20px;">
          <% if (error.length > 0) { %>
            <span class="alert alert--error"><%= error %></span>
          <% } %>
     </div>

				<form action="/login" method="POST" class="form">
					<div class="form__group">
						<label class="form__label" for="username">Username</label>
						<div class="form__input-wrap">
							<span class="form__prefix">@</span>
							<input
								class="form__input form__input--prefixed"
								type="text"
								id="username"
								name="username"
								placeholder="yourhandle"
								required />
						</div>
					</div>

					<div class="form__group">
						<label class="form__label" for="password">Password</label>
						<input
							class="form__input"
							type="password"
							id="password"
							name="password"
							placeholder="••••••••"
							required />
					</div>

					<button class="btn" type="submit">
						<span class="btn__text">Continue</span>
						<span class="btn__icon">→</span>
					</button>
				</form>

				<p class="card__footer">
					Not a member? <a href="/sign-up" class="link">Sign up</a>
				</p>
			</div>
		</div>
	</body>
</html>
