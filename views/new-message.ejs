<!-- views/new-message.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>New Message — Odin Clubhouse</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>

  <div class="scene">
    <div class="noise"></div>

    <div class="index-wrap">

      <!-- Nav -->
      <nav class="nav">
        <div class="logo">
          <span class="logo__icon">✦</span>
        </div>
        <div class="nav__links">
          <a href="/" class="nav__logout">← Back</a>
          <a href="/logout" class="nav__logout">Logout</a>
        </div>
      </nav>

      <!-- Header -->
      <header class="index-header">
        <h1 class="index-title">Post a message</h1>
        <p class="index-subtitle">Your words to the room.</p>
      </header>

      <% if (locals.error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <div class="card">
        <form action="/messages" method="POST" class="form" >

          <div class="form__group">
            <label class="form__label" for="title">Title</label>
            <input
              class="form__input"
              type="text"
              id="title"
              name="title"
              placeholder="Give it a headline..."
              value="<%= locals.body ? body.title : '' %>"
              required
            />
               <% if (errors && errors.title) { %>
            <span class="alert alert--error"><%= errors.title.msg  %></span>
          <% } %>
          </div>

          <div class="form__group">
            <label class="form__label" for="content">Message</label>
            <textarea
              class="form__input form__textarea"
              id="content"
              name="content"
              placeholder="Say something worth remembering..."
              rows="6"
              required
            ><%= locals.body ? body.content : '' %></textarea>
               <% if (errors && errors.content) { %>
            <span class="alert alert--error"><%= errors.content.msg  %></span>
          <% } %>
          </div>

          <button class="btn" type="submit">
            <span class="btn__text">Post to the room</span>
            <span class="btn__icon">→</span>
          </button>

        </form>
      </div>

    </div>
  </div>

</body>
</html>